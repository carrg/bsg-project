{
    "name": "bsg-project-etl",
    "description": "Data Pipeline Application",
    "artifact": {
        "name": "cdap-data-pipeline",
        "version": "6.11.1",
        "scope": "SYSTEM"
    },
    "config": {
        "resources": {
            "memoryMB": 2048,
            "virtualCores": 1
        },
        "driverResources": {
            "memoryMB": 2048,
            "virtualCores": 1
        },
        "connections": [
            {
                "from": "customers_source",
                "to": "Wrangler"
            },
            {
                "from": "Wrangler",
                "to": "BigQuery"
            }
        ],
        "comments": [],
        "postActions": [],
        "properties": {},
        "processTimingEnabled": true,
        "stageLoggingEnabled": false,
        "stages": [
            {
                "name": "customers_source",
                "plugin": {
                    "name": "GCSFile",
                    "type": "batchsource",
                    "label": "customers_source",
                    "artifact": {
                        "name": "google-cloud",
                        "version": "0.24.1",
                        "scope": "SYSTEM"
                    },
                    "properties": {
                        "useConnection": "true",
                        "referenceName": "bsg-project-lake-bucket.",
                        "path": "gs://bsg-project-lake-bucket/raw/customers/customers.csv",
                        "format": "csv",
                        "sampleSize": "1000",
                        "filenameOnly": "false",
                        "recursive": "false",
                        "ignoreNonExistingFolders": "false",
                        "encrypted": "false",
                        "fileEncoding": "UTF-8",
                        "schema": "{\"type\":\"record\",\"name\":\"text\",\"fields\":[{\"name\":\"customer_id\",\"type\":\"int\"},{\"name\":\"name\",\"type\":\"string\"},{\"name\":\"email\",\"type\":\"string\"},{\"name\":\"phone\",\"type\":\"long\"},{\"name\":\"city\",\"type\":\"string\"}]}",
                        "connection": "${conn(Cloud Storage Default)}",
                        "enableQuotedValues": "true",
                        "skipHeader": "true"
                    }
                },
                "outputSchema": "{\"type\":\"record\",\"name\":\"text\",\"fields\":[{\"name\":\"customer_id\",\"type\":\"int\"},{\"name\":\"name\",\"type\":\"string\"},{\"name\":\"email\",\"type\":\"string\"},{\"name\":\"phone\",\"type\":\"long\"},{\"name\":\"city\",\"type\":\"string\"}]}",
                "id": "customers_source",
                "type": "batchsource",
                "label": "customers_source",
                "icon": "fa-plug",
                "$$hashKey": "object:32",
                "isPluginAvailable": true,
                "_uiPosition": {
                    "left": "560px",
                    "top": "336.5px"
                }
            },
            {
                "name": "Wrangler",
                "plugin": {
                    "name": "Wrangler",
                    "type": "transform",
                    "label": "Wrangler",
                    "artifact": {
                        "name": "wrangler-transform",
                        "version": "4.11.1",
                        "scope": "SYSTEM"
                    },
                    "properties": {
                        "field": "*",
                        "expressionLanguage": "jexl",
                        "precondition": "false",
                        "on-error": "fail-pipeline",
                        "schema": "{\"type\":\"record\",\"name\":\"etlSchemaBody\",\"fields\":[{\"name\":\"customer_id\",\"type\":\"int\"},{\"name\":\"name\",\"type\":\"string\"},{\"name\":\"email\",\"type\":\"string\"},{\"name\":\"phone\",\"type\":[\"string\",\"null\"]},{\"name\":\"city\",\"type\":\"string\"}]}",
                        "workspaceId": "8be2da90-509f-4eae-860c-13dde4417c09"
                    }
                },
                "outputSchema": [
                    {
                        "name": "etlSchemaBody",
                        "schema": "{\"type\":\"record\",\"name\":\"etlSchemaBody\",\"fields\":[{\"name\":\"customer_id\",\"type\":\"int\"},{\"name\":\"name\",\"type\":\"string\"},{\"name\":\"email\",\"type\":\"string\"},{\"name\":\"phone\",\"type\":[\"string\",\"null\"]},{\"name\":\"city\",\"type\":\"string\"}]}"
                    }
                ],
                "inputSchema": [
                    {
                        "name": "customers_source",
                        "schema": "{\"type\":\"record\",\"name\":\"text\",\"fields\":[{\"name\":\"customer_id\",\"type\":\"int\"},{\"name\":\"name\",\"type\":\"string\"},{\"name\":\"email\",\"type\":\"string\"},{\"name\":\"phone\",\"type\":\"long\"},{\"name\":\"city\",\"type\":\"string\"}]}"
                    }
                ],
                "id": "Wrangler",
                "type": "transform",
                "label": "Wrangler",
                "icon": "icon-DataPreparation",
                "$$hashKey": "object:33",
                "isPluginAvailable": true,
                "_uiPosition": {
                    "left": "860px",
                    "top": "336.5px"
                }
            },
            {
                "name": "BigQuery",
                "plugin": {
                    "name": "BigQueryTable",
                    "type": "batchsink",
                    "label": "BigQuery",
                    "artifact": {
                        "name": "google-cloud",
                        "version": "0.24.1",
                        "scope": "SYSTEM"
                    },
                    "properties": {
                        "useConnection": "true",
                        "connection": "${conn(BigQuery Default)}",
                        "dataset": "bsg_project_dw",
                        "table": "customers",
                        "operation": "insert",
                        "allowSchemaRelaxation": "true",
                        "readTimeout": "120",
                        "location": "US",
                        "createPartitionedTable": "false",
                        "partitioningType": "TIME",
                        "timePartitioningType": "DAY",
                        "partitionFilterRequired": "false",
                        "schema": "{\"name\":\"etlSchemaBody\",\"type\":\"record\",\"fields\":[{\"name\":\"customer_id\",\"type\":\"int\"},{\"name\":\"name\",\"type\":[\"string\",\"null\"]},{\"name\":\"email\",\"type\":[\"string\",\"null\"]},{\"name\":\"phone\",\"type\":[\"string\",\"null\"]},{\"name\":\"city\",\"type\":[\"string\",\"null\"]}]}",
                        "truncateTable": "true"
                    }
                },
                "outputSchema": [
                    {
                        "name": "etlSchemaBody",
                        "schema": "{\"name\":\"etlSchemaBody\",\"type\":\"record\",\"fields\":[{\"name\":\"customer_id\",\"type\":\"int\"},{\"name\":\"name\",\"type\":[\"string\",\"null\"]},{\"name\":\"email\",\"type\":[\"string\",\"null\"]},{\"name\":\"phone\",\"type\":[\"string\",\"null\"]},{\"name\":\"city\",\"type\":[\"string\",\"null\"]}]}"
                    }
                ],
                "inputSchema": [
                    {
                        "name": "Wrangler",
                        "schema": "{\"type\":\"record\",\"name\":\"etlSchemaBody\",\"fields\":[{\"name\":\"customer_id\",\"type\":\"int\"},{\"name\":\"name\",\"type\":\"string\"},{\"name\":\"email\",\"type\":\"string\"},{\"name\":\"phone\",\"type\":[\"string\",\"null\"]},{\"name\":\"city\",\"type\":\"string\"}]}"
                    }
                ],
                "id": "BigQuery",
                "type": "batchsink",
                "label": "BigQuery",
                "icon": "fa-plug",
                "$$hashKey": "object:34",
                "isPluginAvailable": true,
                "_uiPosition": {
                    "left": "1160px",
                    "top": "336.5px"
                }
            }
        ],
        "schedule": "0 1 */1 * *",
        "engine": "spark",
        "numOfRecordsPreview": 100,
        "rangeRecordsPreview": {
            "min": 1,
            "max": "5000"
        },
        "description": "Data Pipeline Application",
        "maxConcurrentRuns": 1,
        "pushdownEnabled": false,
        "transformationPushdown": {}
    },
    "version": "50c5aa32-322b-11f1-8622-86ff6b68bb8b"
}